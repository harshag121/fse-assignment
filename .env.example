# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# For local Docker: postgresql+asyncpg://docuser:docpass@db:5432/docappointment
# For Railway PostgreSQL: copy the connection string from the Railway dashboard
DATABASE_URL=postgresql+asyncpg://docuser:docpass@localhost:5432/docappointment

# Only needed for docker-compose.prod.yml self-hosted deploys
POSTGRES_USER=docuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=docappointment

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ── LLM (Groq — free, fast) ───────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Enable 2FA on your Google account, then create an App Password:
# myaccount.google.com → Security → App Passwords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Slack notifications ───────────────────────────────────────────────────────
# Create a bot at api.slack.com/apps, grant chat:write scope, install to workspace
SLACK_BOT_TOKEN=xoxb-...
# Use a channel ID (e.g. C0XXXXXXXXX) or a DM user ID (e.g. U0XXXXXXXXX)
SLACK_DEFAULT_CHANNEL=U0XXXXXXXXX

# ── Twilio WhatsApp (optional) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Google Calendar (optional) ────────────────────────────────────────────────
# Paste the full JSON contents of your service account credentials file (single line)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── CORS — Production frontend URL ────────────────────────────────────────────
# Set this to your deployed frontend URL so the backend allows cross-origin requests
# e.g. https://my-frontend.up.railway.app
FRONTEND_URL=

# ── MCP Server URL ─────────────────────────────────────────────────────────────
# URL of the standalone MCP server that the FastAPI backend (MCP client) connects to.
# Local dev:  http://localhost:8001/sse
# Docker:     http://mcp-server:8001/sse  (set automatically by docker-compose.yml)
MCP_SERVER_URL=http://localhost:8001/sse

# ── Frontend — Backend URL (set at build time for the nginx Docker image) ─────
# Set this to your deployed backend URL when building the frontend Docker image
# e.g. https://my-backend.up.railway.app
REACT_APP_API_URL=
