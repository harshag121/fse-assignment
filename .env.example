# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://docuser:docpass@localhost:5432/docappointment

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production

# ── LLM ──────────────────────────────────────────────────────────────────────
# Use OpenAI GPT-4o (recommended) or swap to Anthropic
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# ── Google Calendar ───────────────────────────────────────────────────────────
# Paste the full JSON contents of your service account credentials
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG...
FROM_EMAIL=noreply@yourdomain.com

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack (primary)
SLACK_BOT_TOKEN=xoxb-...
SLACK_DEFAULT_CHANNEL=#doctor-reports

# Twilio WhatsApp (fallback)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
